{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.0.1",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "content_scripts": [
    {
      "matches": [
        "https://*.pathofexile.com/trade2/search/**"
      ],
      "js": ["locales.js", "script.js"]
    }
